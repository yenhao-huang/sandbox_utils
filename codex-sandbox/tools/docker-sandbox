#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  docker sandbox create <name> <repo_path> <mount_path> [mount_path...]
  docker sandbox run <name>
  docker sandbox run <name> <command> [args...]

Examples:
  docker sandbox create codex /path/to/your/repo .
  docker sandbox create codex /path/to/your/repo pyproject.toml src tests
  docker sandbox run codex
  docker sandbox run codex codex --version

Environment:
  DOCKER_SANDBOX_IMAGE   Optional published image, for example howard/codex-sandbox:latest
  DOCKER_SANDBOX_DOCKERFILE  Optional Dockerfile path for local builds
  DOCKER_SANDBOX_MOUNT_DIR  Host staging directory, default /tmp2/howard/codex-sandbox
EOF
}

metadata() {
  cat <<'EOF'
{"SchemaVersion":"0.1.0","Vendor":"local","Version":"0.1.0","ShortDescription":"Run Codex in a Docker sandbox for any repo"}
EOF
}

die() {
  echo "error: $*" >&2
  exit 1
}

docker_tty_args=()
if [ -t 0 ] && [ -t 1 ]; then
  docker_tty_args=(-it)
fi

resolve_path() {
  local path="$1"
  [ -n "$path" ] || die "repo_path is required"
  [ -d "$path" ] || die "repo path does not exist: $path"
  cd "$path" && pwd
}

clear_directory() {
  local dir="$1"
  mkdir -p "$dir"
  find "$dir" -mindepth 1 -maxdepth 1 -exec rm -rf -- {} +
}

resolve_dockerfile() {
  local repo_path="$1"
  local dockerfile_override="${DOCKER_SANDBOX_DOCKERFILE:-}"
  local dockerfile_path=""

  if [ -n "$dockerfile_override" ]; then
    if [ -f "$dockerfile_override" ]; then
      dockerfile_path="$dockerfile_override"
    elif [ -f "${repo_path}/${dockerfile_override}" ]; then
      dockerfile_path="${repo_path}/${dockerfile_override}"
    else
      die "dockerfile does not exist: ${dockerfile_override}"
    fi
  elif [ -f "${repo_path}/docker/data-crawl/Dockerfile" ]; then
    dockerfile_path="${repo_path}/docker/data-crawl/Dockerfile"
  elif [ -f "${repo_path}/Dockerfile" ]; then
    dockerfile_path="${repo_path}/Dockerfile"
  else
    die "no Dockerfile found under ${repo_path}. Set DOCKER_SANDBOX_DOCKERFILE or use DOCKER_SANDBOX_IMAGE"
  fi

  cd "$(dirname "$dockerfile_path")" && printf '%s/%s\n' "$(pwd)" "$(basename "$dockerfile_path")"
}

write_mounts_file() {
  local mounts_file="$1"
  shift
  : >"$mounts_file"
  [ "$#" -gt 0 ] || die "at least one mount path is required; use '.' to sync the whole repo"
  for mount_path in "$@"; do
    [ -n "$mount_path" ] || continue
    printf '%s\n' "$mount_path" >>"$mounts_file"
  done
}

sync_workspace() {
  local repo_path="$1"
  local workspace_path="$2"
  local mounts_file="$3"
  local mount_path=""
  local src=""
  local dest_parent=""

  clear_directory "$workspace_path"

  while IFS= read -r mount_path || [ -n "$mount_path" ]; do
    [ -n "$mount_path" ] || continue
    if [ "$mount_path" = "." ]; then
      cp -a "${repo_path}/." "${workspace_path}/"
      continue
    fi
    src="${repo_path}/${mount_path}"
    [ -e "$src" ] || die "mount path does not exist under repo: ${mount_path}"
    dest_parent="${workspace_path}/$(dirname "$mount_path")"
    mkdir -p "$dest_parent"
    cp -a "$src" "$dest_parent/"
  done <"$mounts_file"
}

docker_config_root="${DOCKER_CONFIG:-${HOME}/.docker}"
state_root="${docker_config_root}/sandboxes"
mkdir -p "$state_root"

if [ "${1:-}" = "sandbox" ]; then
  shift
fi

subcommand="${1:-}"
case "$subcommand" in
  docker-cli-plugin-metadata)
    metadata
    ;;

  create)
    [ "$#" -ge 3 ] || die "expected: create <name> <repo_path> [mount_path...]"
    name="$2"
    repo_path="$(resolve_path "$3")"
    shift 3
    host_uid="$(id -u)"
    host_gid="$(id -g)"
    state_file="${state_root}/${name}.env"
    sandbox_base_dir="${DOCKER_SANDBOX_MOUNT_DIR:-/tmp2/howard/codex-sandbox}"
    sandbox_root="${sandbox_base_dir}/${name}"
    workspace_path="${sandbox_root}/workspace"
    codex_home_host_path="${sandbox_root}/.codex-docker"
    mounts_file="${sandbox_root}/mounts.list"
    dockerfile_path=""
    if [ -z "${DOCKER_SANDBOX_IMAGE:-}" ]; then
      dockerfile_path="$(resolve_dockerfile "$repo_path")"
    fi

    mkdir -p "${sandbox_root}" "${codex_home_host_path}"
    write_mounts_file "${mounts_file}" "$@"
    sync_workspace "${repo_path}" "${workspace_path}" "${mounts_file}"

    cat >"$state_file" <<EOF
NAME=${name}
REPO_PATH=${repo_path}
HOST_UID=${host_uid}
HOST_GID=${host_gid}
IMAGE_TAG=docker-sandbox-${name}
IMAGE_REF=${DOCKER_SANDBOX_IMAGE:-}
DOCKERFILE_PATH=${dockerfile_path}
SANDBOX_ROOT=${sandbox_root}
WORKSPACE_PATH=${workspace_path}
CODEX_HOME_HOST_PATH=${codex_home_host_path}
MOUNTS_FILE=${mounts_file}
EOF

    cat <<EOF
created sandbox: ${name}
repo: ${repo_path}
state: ${state_file}
image: ${DOCKER_SANDBOX_IMAGE:-local build}
dockerfile: ${dockerfile_path:-n/a}
workspace: ${workspace_path}
codex_home: ${codex_home_host_path}
mounts: ${mounts_file}

next:
  docker sandbox run ${name}
EOF
    ;;

  run)
    [ "$#" -ge 2 ] || die "expected: run <name> [command...]"
    name="$2"
    shift 2
    state_file="${state_root}/${name}.env"
    [ -f "$state_file" ] || die "sandbox not found: ${name}. run 'docker sandbox create ${name} <repo_path>' first"
    . "$state_file"

    [ -n "${SANDBOX_ROOT:-}" ] || die "state is missing SANDBOX_ROOT. recreate the sandbox"
    [ -n "${WORKSPACE_PATH:-}" ] || die "state is missing WORKSPACE_PATH. recreate the sandbox"
    [ -n "${CODEX_HOME_HOST_PATH:-}" ] || die "state is missing CODEX_HOME_HOST_PATH. recreate the sandbox"
    [ -n "${MOUNTS_FILE:-}" ] || die "state is missing MOUNTS_FILE. recreate the sandbox"

    sync_workspace "${REPO_PATH}" "${WORKSPACE_PATH}" "${MOUNTS_FILE}"

    runtime_dir="${CODEX_HOME_HOST_PATH}/.runtime"
    mkdir -p "${CODEX_HOME_HOST_PATH}" "${runtime_dir}"

    cat >"${runtime_dir}/passwd" <<EOF
root:x:0:0:root:/root:/bin/bash
codex:x:${HOST_UID}:${HOST_GID}:Codex User:/workspace/.codex-docker/home:/bin/bash
EOF

    cat >"${runtime_dir}/group" <<EOF
root:x:0:
codex:x:${HOST_GID}:
EOF

    image_to_run="${IMAGE_TAG}"
    if [ -n "${IMAGE_REF:-}" ]; then
      docker pull "${IMAGE_REF}"
      image_to_run="${IMAGE_REF}"
    else
      [ -n "${DOCKERFILE_PATH:-}" ] || die "state is missing DOCKERFILE_PATH. recreate the sandbox"
      docker build \
        --build-arg UID="${HOST_UID}" \
        --build-arg GID="${HOST_GID}" \
        --build-arg USERNAME=codex \
        -t "${IMAGE_TAG}" \
        -f "${DOCKERFILE_PATH}" \
        "${REPO_PATH}"
    fi

    exec docker run --rm "${docker_tty_args[@]}" \
      -u "${HOST_UID}:${HOST_GID}" \
      -w /workspace \
      --security-opt seccomp=unconfined \
      --security-opt apparmor=unconfined \
      --cap-add SYS_ADMIN \
      --cap-add NET_ADMIN \
      -e HOME=/workspace/.codex-docker/home \
      -e USER=codex \
      -e CODEX_HOME=/workspace/.codex-docker/state \
      -e FIRECRAWL_API_KEY="${FIRECRAWL_API_KEY:-}" \
      -v "${WORKSPACE_PATH}:/workspace" \
      -v "${CODEX_HOME_HOST_PATH}:/workspace/.codex-docker" \
      -v "${runtime_dir}/passwd:/etc/passwd:ro" \
      -v "${runtime_dir}/group:/etc/group:ro" \
      "${image_to_run}" \
      "${@:-bash}"
    ;;

  ""|-h|--help|help)
    usage
    ;;

  *)
    die "unknown subcommand: ${subcommand}"
    ;;
esac
